# Copy to .env and adjust for your deployment.

# Mount the whole app under a sub-path (used when hosting at /gis).
GIS_URL_PREFIX=/gis

# Bind address and port for the waitress server.
GIS_HOST=127.0.0.1
GIS_PORT=5006

# Optional: pin a specific Overpass mirror (otherwise public mirrors are tried).
# GIS_OVERPASS_URL=https://overpass-api.de/api/interpreter

# Optional: self-hosted Nominatim base URL (no trailing slash).
# GIS_NOMINATIM_URL=https://nominatim.openstreetmap.org

# "Ask the City" (LLM). Required to enable the feature; leave unset to disable.
# ANTHROPIC_API_KEY=sk-ant-...
# GIS_ASK_MODEL=claude-opus-4-8        # or claude-haiku-4-5 for faster/cheaper
# GIS_ASK_RATE_LIMIT=8                  # max questions per IP per window
# GIS_ASK_RATE_WINDOW=60               # window in seconds
